generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(255)
  code            Int              @unique
  phone           String?          @db.VarChar(20)
  address         String?
  category        String?          @db.VarChar(100)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accountId       Int?             @unique
  account         Account?         @relation(fields: [accountId], references: [id])
  quotations      Quotation[]
  receiptVouchers ReceiptVoucher[]
  invoices        SalesInvoice[]
  salesReturns    SalesReturn[]
}

model Supplier {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  code            Int               @unique
  phone           String?           @db.VarChar(20)
  address         String?
  category        String?           @db.VarChar(100)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accountId       Int?              @unique
  paymentVouchers PaymentVoucher[]
  invoices        PurchaseInvoice[]
  purchaseReturns PurchaseReturn[]
  account         Account?          @relation(fields: [accountId], references: [id])
}

model SalesInvoice {
  id             Int                @id @default(autoincrement())
  invoiceNumber  Int                @unique
  customerName   String             @db.VarChar(255)
  customerId     Int
  invoiceDate    DateTime
  subtotal       Float
  totalTax       Float
  discount       Float              @default(0)
  total          Float
  status         InvoiceStatus      @default(cash)
  safeId         Int?
  bankId         Int?
  description    String?
  topNotes       Json?
  notes          Json?
  printableTitle String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  dueDate        DateTime?
  bank           TreasuryBank?      @relation(fields: [bankId], references: [id])
  customer       Customer           @relation(fields: [customerId], references: [id])
  safe           TreasurySafe?      @relation(fields: [safeId], references: [id])
  items          SalesInvoiceItem[]
  salesReturns   SalesReturn[]
}

model SalesInvoiceItem {
  id           Int          @id @default(autoincrement())
  invoiceId    Int
  description  String       @db.VarChar(255)
  quantity     Float
  unitPrice    Float
  taxRate      Float        @default(0)
  discount     Float        @default(0)
  total        Float
  productId    Int?
  profitMargin Float        @default(0)
  invoice      SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])
}

model PurchaseInvoice {
  id              Int                   @id @default(autoincrement())
  invoiceNumber   Int                   @unique
  supplierName    String                @db.VarChar(255)
  supplierId      Int
  invoiceDate     DateTime
  subtotal        Float
  totalTax        Float
  discount        Float                 @default(0)
  total           Float
  status          InvoiceStatus         @default(cash)
  safeId          Int?
  bankId          Int?
  description     String?
  topNotes        Json?
  notes           Json?
  printableTitle  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  dueDate         DateTime?
  bank            TreasuryBank?         @relation(fields: [bankId], references: [id])
  safe            TreasurySafe?         @relation(fields: [safeId], references: [id])
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  items           PurchaseInvoiceItem[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseInvoiceItem {
  id           Int             @id @default(autoincrement())
  invoiceId    Int
  description  String          @db.VarChar(255)
  quantity     Float
  unitPrice    Float
  sellingPrice Float           @default(0)
  profitMargin Float           @default(0)
  taxRate      Float           @default(0)
  discount     Float           @default(0)
  total        Float
  productId    Int?
  invoice      PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product      Product?        @relation(fields: [productId], references: [id])
}

model TreasurySafe {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  balance          Float              @default(0)
  description      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isPrimary        Boolean            @default(false)
  isActive         Boolean            @default(true)
  accountId        Int?               @unique
  paymentVouchers  PaymentVoucher[]
  purchaseInvoices PurchaseInvoice[]
  purchaseReturns  PurchaseReturn[]
  receiptVouchers  ReceiptVoucher[]
  salesInvoices    SalesInvoice[]
  salesReturns     SalesReturn[]
  account          Account?           @relation(fields: [accountId], references: [id])
  transfersFrom    TreasuryTransfer[] @relation("TransferFromSafe")
  transfersTo      TreasuryTransfer[] @relation("TransferToSafe")
}

model TreasuryBank {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  accountNumber    String?            @db.VarChar(100)
  branch           String?            @db.VarChar(255)
  balance          Float              @default(0)
  description      String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  accountId        Int?               @unique
  paymentVouchers  PaymentVoucher[]
  purchaseInvoices PurchaseInvoice[]
  purchaseReturns  PurchaseReturn[]
  receiptVouchers  ReceiptVoucher[]
  salesInvoices    SalesInvoice[]
  salesReturns     SalesReturn[]
  account          Account?           @relation(fields: [accountId], references: [id])
  transfersFrom    TreasuryTransfer[] @relation("TransferFromBank")
  transfersTo      TreasuryTransfer[] @relation("TransferToBank")
}

model ReceiptVoucher {
  id              Int              @id @default(autoincrement())
  voucherNumber   String           @unique @db.VarChar(50)
  date            DateTime
  amount          Float
  description     String?
  customerId      Int
  accountType     String           @db.VarChar(10)
  safeId          Int?
  bankId          Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bank            TreasuryBank?    @relation(fields: [bankId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  safe            TreasurySafe?    @relation(fields: [safeId], references: [id])
  purchaseReturns PurchaseReturn[] @relation("PurchaseReturnToReceiptVoucher")

  @@index([customerId])
  @@index([safeId])
  @@index([bankId])
}

model PaymentVoucher {
  id            Int           @id @default(autoincrement())
  voucherNumber String        @unique @db.VarChar(50)
  date          DateTime
  amount        Float
  description   String?
  accountType   String        @db.VarChar(10)
  safeId        Int?
  bankId        Int?
  supplierId    Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bank          TreasuryBank? @relation(fields: [bankId], references: [id])
  safe          TreasurySafe? @relation(fields: [safeId], references: [id])
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  salesReturns  SalesReturn[] @relation("PaymentVoucherToSalesReturn")

  @@index([supplierId])
  @@index([safeId])
  @@index([bankId])
}

model SalesReturn {
  id              Int               @id @default(autoincrement())
  returnNumber    Int               @unique
  invoiceId       Int
  customerId      Int
  returnDate      DateTime
  subtotal        Float
  discount        Float             @default(0)
  totalTax        Float             @default(0)
  total           Float
  reason          String?
  status          ReturnStatus      @default(pending)
  refundMethod    RefundMethod      @default(cash)
  safeId          Int?
  bankId          Int?
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  bank            TreasuryBank?     @relation(fields: [bankId], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  invoice         SalesInvoice      @relation(fields: [invoiceId], references: [id])
  safe            TreasurySafe?     @relation(fields: [safeId], references: [id])
  items           SalesReturnItem[]
  paymentVouchers PaymentVoucher[]  @relation("PaymentVoucherToSalesReturn")

  @@index([invoiceId])
  @@index([customerId])
  @@index([returnDate])
}

model SalesReturnItem {
  id            Int         @id @default(autoincrement())
  returnId      Int
  invoiceItemId Int?
  description   String      @db.VarChar(255)
  quantity      Float
  unitPrice     Float
  taxRate       Float       @default(0)
  total         Float
  return        SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model PurchaseReturn {
  id              Int                  @id @default(autoincrement())
  returnNumber    Int                  @unique
  invoiceId       Int
  supplierId      Int
  returnDate      DateTime
  subtotal        Float
  discount        Float                @default(0)
  totalTax        Float                @default(0)
  total           Float
  reason          String?
  status          ReturnStatus         @default(pending)
  refundMethod    RefundMethod         @default(cash)
  safeId          Int?
  bankId          Int?
  description     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  bank            TreasuryBank?        @relation(fields: [bankId], references: [id])
  invoice         PurchaseInvoice      @relation(fields: [invoiceId], references: [id])
  safe            TreasurySafe?        @relation(fields: [safeId], references: [id])
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  items           PurchaseReturnItem[]
  receiptVouchers ReceiptVoucher[]     @relation("PurchaseReturnToReceiptVoucher")

  @@index([invoiceId])
  @@index([supplierId])
  @@index([returnDate])
}

model PurchaseReturnItem {
  id            Int            @id @default(autoincrement())
  returnId      Int
  invoiceItemId Int?
  description   String         @db.VarChar(255)
  quantity      Float
  unitPrice     Float
  taxRate       Float          @default(0)
  total         Float
  return        PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  code      String?   @unique @db.VarChar(50)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  imageUrl  String?
  products  Product[]
}

model Warehouse {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(100)
  location       String?         @db.VarChar(255)
  isDefault      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
}

model Product {
  id                   Int                   @id @default(autoincrement())
  code                 String                @unique @db.VarChar(50)
  name                 String                @db.VarChar(255)
  unit                 String?               @db.VarChar(50)
  buyPrice             Float                 @default(0)
  sellPrice            Float                 @default(0)
  profitMargin         Float                 @default(0)
  taxRate              Float                 @default(0)
  minStock             Float                 @default(0)
  currentStock         Float                 @default(0)
  isActive             Boolean               @default(true)
  categoryId           Int?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  imageUrl             String?
  category             Category?             @relation(fields: [categoryId], references: [id])
  purchaseInvoiceItems PurchaseInvoiceItem[]
  quotationItems       QuotationItem[]
  salesInvoiceItems    SalesInvoiceItem[]
  stockMovements       StockMovement[]
}

model StockMovement {
  id                Int          @id @default(autoincrement())
  productId         Int
  movementType      MovementType
  quantity          Float
  unitPrice         Float        @default(0)
  reference         String?      @db.VarChar(100)
  notes             String?
  warehouseId       Int?
  purchaseInvoiceId Int?
  salesInvoiceId    Int?
  purchaseReturnId  Int?
  salesReturnId     Int?
  createdAt         DateTime     @default(now())
  product           Product      @relation(fields: [productId], references: [id])
  warehouse         Warehouse?   @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
  @@index([warehouseId])
}

model Quotation {
  id             Int             @id @default(autoincrement())
  code           String          @unique @db.VarChar(20)
  customerId     Int?
  customerName   String?         @db.VarChar(255)
  date           DateTime
  subtotal       Float
  totalTax       Float           @default(0)
  discount       Float           @default(0)
  total          Float
  topNotes       Json?
  notes          Json?
  printableTitle String?
  status         QuotationStatus @default(Draft)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  customer       Customer?       @relation(fields: [customerId], references: [id])
  items          QuotationItem[]

  @@index([customerId])
  @@index([date])
}

model QuotationItem {
  id          Int       @id @default(autoincrement())
  quotationId Int
  productId   Int?
  description String    @db.VarChar(255)
  quantity    Float
  unitPrice   Float
  taxRate     Float     @default(0)
  discount    Float     @default(0)
  total       Float
  product     Product?  @relation(fields: [productId], references: [id])
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model TreasuryTransfer {
  id             Int           @id @default(autoincrement())
  transferNumber String        @unique @db.VarChar(50)
  date           DateTime
  amount         Float
  description    String?
  fromType       String        @db.VarChar(10)
  fromSafeId     Int?
  fromBankId     Int?
  toType         String        @db.VarChar(10)
  toSafeId       Int?
  toBankId       Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  fromBank       TreasuryBank? @relation("TransferFromBank", fields: [fromBankId], references: [id])
  fromSafe       TreasurySafe? @relation("TransferFromSafe", fields: [fromSafeId], references: [id])
  toBank         TreasuryBank? @relation("TransferToBank", fields: [toBankId], references: [id])
  toSafe         TreasurySafe? @relation("TransferToSafe", fields: [toSafeId], references: [id])

  @@index([fromSafeId])
  @@index([fromBankId])
  @@index([toSafeId])
  @@index([toBankId])
}

model SystemSettings {
  id        Int      @id @default(1)
  settings  Json
  updatedAt DateTime @updatedAt
}

model User {
  id                       Int                     @id @default(autoincrement())
  username                 String                  @unique @db.VarChar(50)
  password                 String                  @db.VarChar(255)
  role                     String                  @default("WORKER") @db.VarChar(20)
  authorizedDevices        String[]                @default([])
  maxDevices               Int                     @default(1)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  email                    String?                 @unique @db.VarChar(255)
  tenantSchema             String?                 @db.VarChar(100)
  parentId                 Int?
  parent                   User?                   @relation("UserHierarchy", fields: [parentId], references: [id])
  children                 User[]                  @relation("UserHierarchy")
  modifiedAccounts         Account[]               @relation("AccountModifier")
  createdJournalEntries    JournalEntry[]          @relation("JournalCreator")
  notifications            Notification[]
  sessions                 Session[]
  approvedTreasuryRequests TreasuryActionRequest[] @relation("Approver")
  treasuryRequests         TreasuryActionRequest[] @relation("Requester")
}

/// Developer-controlled system branding (system name + logo).
/// Separate from CompanySettings which belongs to the purchasing client.
model SystemConfig {
  id         Int      @id @default(1)
  systemName String   @default("نظام محاسبة فاست")
  systemLogo String?
  updatedAt  DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CompanySettings {
  id                  Int      @id @default(1)
  companyName         String?  @default("شركة المحاسبة الحديثة")
  companyNameEn       String?  @default("Modern Accounting Co.")
  companyLogo         String?
  companyStamp        String?
  showLogoOnPrint     Boolean  @default(true)
  showStampOnPrint    Boolean  @default(true)
  salesPrefix         String   @default("INV")
  purchasePrefix      String   @default("PUR")
  quotationPrefix     String   @default("QUO")
  invoiceName         String   @default("فاتورة ضريبية")
  startNumber         Int      @default(1)
  termsAndConditions  String?
  taxEnabled          Boolean  @default(true)
  taxName             String   @default("VAT")
  taxPercentage       Float    @default(15)
  taxType             TaxType  @default(EXCLUSIVE)
  currencyCode        String   @default("ج.م")
  decimalPlaces       Int      @default(2)
  updatedAt           DateTime @updatedAt
  purchaseInvoiceName String   @default("فاتورة مشتريات")
  salesInvoiceName    String   @default("فاتورة مبيعات")
  companyBarcode      String?
  showBarcodeOnPrint  Boolean  @default(true)
  invoiceFooterNotes  String?
}

model Notification {
  id        Int              @id @default(autoincrement())
  title     String           @db.VarChar(255)
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  userId    Int?
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id])
}

model GeneralSettings {
  id                             Int      @id @default(1)
  staffActivityAlerts            Boolean  @default(true)
  inventoryAlerts                Boolean  @default(true)
  vaultBankAlerts                Boolean  @default(true)
  minVaultBalance                Float    @default(1000)
  financialAlerts                Boolean  @default(true)
  showDueDateOnInvoices          Boolean  @default(false)
  updatedAt                      DateTime @updatedAt
  requireApprovalForTransfers    Boolean  @default(false)
  requireApprovalForSafeCreation Boolean  @default(false)
  requireApprovalForBankCreation Boolean  @default(false)
  requireApprovalForVouchers     Boolean  @default(false)
}

model TreasuryActionRequest {
  id          Int                @id @default(autoincrement())
  type        TreasuryActionType
  data        Json
  status      RequestStatus      @default(PENDING)
  reason      String?
  requesterId Int
  approverId  Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  approver    User?              @relation("Approver", fields: [approverId], references: [id])
  requester   User               @relation("Requester", fields: [requesterId], references: [id])

  @@index([requesterId])
  @@index([approverId])
  @@index([status])
}

model Account {
  id               Int           @id @default(autoincrement())
  code             String        @unique
  name             String        @db.VarChar(255)
  nameEn           String?       @db.VarChar(255)
  type             AccountType
  parentId         Int?
  isSelectable     Boolean       @default(true)
  isTerminal       Boolean       @default(false)
  level            Int           @default(1)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lastModifiedById Int?
  lastModifiedBy   User?         @relation("AccountModifier", fields: [lastModifiedById], references: [id])
  parent           Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         Account[]     @relation("AccountHierarchy")
  customer         Customer?
  journalItems     JournalItem[]
  supplier         Supplier?
  treasuryBank     TreasuryBank?
  treasurySafe     TreasurySafe?

  @@index([parentId])
  @@index([code])
}

model JournalEntry {
  id          Int           @id @default(autoincrement())
  entryNumber Int           @unique
  date        DateTime
  description String?
  reference   String?       @db.VarChar(100)
  sourceType  SourceType    @default(MANUAL)
  sourceId    Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById Int?
  createdBy   User?         @relation("JournalCreator", fields: [createdById], references: [id])
  items       JournalItem[]

  @@index([date])
  @@index([sourceType, sourceId])
}

model JournalItem {
  id             Int          @id @default(autoincrement())
  journalEntryId Int
  accountId      Int
  description    String?
  debit          Float        @default(0)
  credit         Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([journalEntryId])
}

model SystemSequence {
  id        String   @id
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum InvoiceStatus {
  cash
  credit
  pending
}

enum ReturnStatus {
  pending
  completed
  rejected
}

enum RefundMethod {
  cash
  safe
  bank
  credit
}

enum MovementType {
  PURCHASE
  SALE
  PURCHASE_RETURN
  SALE_RETURN
  ADJUSTMENT
}

enum QuotationStatus {
  Draft
  Sent
  Approved
  Rejected
  Converted
}

enum TaxType {
  INCLUSIVE
  EXCLUSIVE
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum TreasuryActionType {
  TRANSFER
  CREATE_SAFE
  CREATE_BANK
  RECEIPT_VOUCHER
  PAYMENT_VOUCHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum SourceType {
  MANUAL
  SALES_INVOICE
  PURCHASE_INVOICE
  RECEIPT_VOUCHER
  PAYMENT_VOUCHER
  SALES_RETURN
  PURCHASE_RETURN
  TRANSFER
}
